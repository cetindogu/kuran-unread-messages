{
  "SurahEnglishName": "Al-Qaari'a",
  "SurahNumber": 101,
  "RevelationOrder": 30,
  "Verses": [
    {
      "RevelationOrder": 494,
      "TurkishTranslation": "Gürültü koparacak olan",
      "ArabicText": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ",
      "Number": 1
    },
    {
      "RevelationOrder": 495,
      "TurkishTranslation": "Nedir o gürültü koparacak olan?",
      "ArabicText": "مَا ٱلْقَارِعَةُ",
      "Number": 2
    },
    {
      "RevelationOrder": 496,
      "TurkishTranslation": "O gürültü koparacak olanın ne olduğunu sen bilir misin?",
      "ArabicText": "وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ",
      "Number": 3
    },
    {
      "RevelationOrder": 497,
      "TurkishTranslation": "O gün insanlar, ateş etrafında çırpınıp dökülen pervaneye dönecekler.",
      "ArabicText": "يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ",
      "Number": 4
    },
    {
      "RevelationOrder": 498,
      "TurkishTranslation": "Dağlar, atılmış renkli yüne benzeyecekler.",
      "ArabicText": "وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ",
      "Number": 5
    },
    {
      "RevelationOrder": 499,
      "TurkishTranslation": "Ama tartıları ağır gelen kimse hoş bir hayat içinde olacaktır.",
      "ArabicText": "فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ",
      "Number": 6
    },
    {
      "RevelationOrder": 500,
      "TurkishTranslation": "Ama tartıları ağır gelen kimse hoş bir hayat içinde olacaktır.",
      "ArabicText": "فَهُوَ فِى عِيشَةٍۢ رَّاضِيَةٍۢ",
      "Number": 7
    },
    {
      "RevelationOrder": 501,
      "TurkishTranslation": "Tartıları hafif gelenler ise,",
      "ArabicText": "وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ",
      "Number": 8
    },
    {
      "RevelationOrder": 502,
      "TurkishTranslation": "Onların yeri bir çukurdur.",
      "ArabicText": "فَأُمُّهُۥ هَاوِيَةٌۭ",
      "Number": 9
    },
    {
      "RevelationOrder": 503,
      "TurkishTranslation": "O çukurun ne olduğunu sen bilir misin?",
      "ArabicText": "وَمَآ أَدْرَىٰكَ مَا هِيَهْ",
      "Number": 10
    },
    {
      "RevelationOrder": 504,
      "TurkishTranslation": "O, kızgın bir ateştir.",
      "ArabicText": "نَارٌ حَامِيَةٌۢ",
      "Number": 11
    }
  ],
  "SurahName": "سُورَةُ القَارِعَةِ"
}
