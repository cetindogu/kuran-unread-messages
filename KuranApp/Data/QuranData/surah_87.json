{
  "SurahEnglishName": "Al-A'laa",
  "SurahNumber": 87,
  "RevelationOrder": 8,
  "Verses": [
    {
      "RevelationOrder": 189,
      "TurkishTranslation": "Yüce Rabbinin adını tesbih et.",
      "ArabicText": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى",
      "Number": 1
    },
    {
      "RevelationOrder": 190,
      "TurkishTranslation": "O, yaratıp şekil vermiştir.",
      "ArabicText": "ٱلَّذِى خَلَقَ فَسَوَّىٰ",
      "Number": 2
    },
    {
      "RevelationOrder": 191,
      "TurkishTranslation": "O, her şeyi ölçüyle yapıp doğru yolu göstermiştir.",
      "ArabicText": "وَٱلَّذِى قَدَّرَ فَهَدَىٰ",
      "Number": 3
    },
    {
      "RevelationOrder": 192,
      "TurkishTranslation": "O, yeşillikler bitirmiştir.",
      "ArabicText": "وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ",
      "Number": 4
    },
    {
      "RevelationOrder": 193,
      "TurkishTranslation": "Sonra da onları siyah çerçöpe çevirmiştir.",
      "ArabicText": "فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ",
      "Number": 5
    },
    {
      "RevelationOrder": 194,
      "TurkishTranslation": "Sana Kuran'ı Biz okutacağız ve asla unutmayacaksın;",
      "ArabicText": "سَنُقْرِئُكَ فَلَا تَنسَىٰٓ",
      "Number": 6
    },
    {
      "RevelationOrder": 195,
      "TurkishTranslation": "Allah'ın dilediği bundan müstesnadır. Doğrusu açığı da, gizliyi de bilen O'dur.",
      "ArabicText": "إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ",
      "Number": 7
    },
    {
      "RevelationOrder": 196,
      "TurkishTranslation": "Kolay olanı yapmayı sana kolaylaştırırız.",
      "ArabicText": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
      "Number": 8
    },
    {
      "RevelationOrder": 197,
      "TurkishTranslation": "Faydalı olacaksa insanlara öğüt ver.",
      "ArabicText": "فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ",
      "Number": 9
    },
    {
      "RevelationOrder": 198,
      "TurkishTranslation": "Allah'tan korkan öğüt alacaktır.",
      "ArabicText": "سَيَذَّكَّرُ مَن يَخْشَىٰ",
      "Number": 10
    },
    {
      "RevelationOrder": 199,
      "TurkishTranslation": "Bedbaht olan ondan kaçınacaktır.",
      "ArabicText": "وَيَتَجَنَّبُهَا ٱلْأَشْقَى",
      "Number": 11
    },
    {
      "RevelationOrder": 200,
      "TurkishTranslation": "O, en büyük ateşe yaslanacaktır.",
      "ArabicText": "ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ",
      "Number": 12
    },
    {
      "RevelationOrder": 201,
      "TurkishTranslation": "O, orada ne ölecektir ne de dirilecektir.",
      "ArabicText": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
      "Number": 13
    },
    {
      "RevelationOrder": 202,
      "TurkishTranslation": "Arınmış olan, Rabbinin adını anıp namaz kılan, saadete erişecektir.",
      "ArabicText": "قَدْ أَفْلَحَ مَن تَزَكَّىٰ",
      "Number": 14
    },
    {
      "RevelationOrder": 203,
      "TurkishTranslation": "Arınmış olan, Rabbinin adını anıp namaz kılan, saadete erişecektir.",
      "ArabicText": "وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ",
      "Number": 15
    },
    {
      "RevelationOrder": 204,
      "TurkishTranslation": "Ama sizler dünya hayatını tercih ediyorsunuz.",
      "ArabicText": "بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
      "Number": 16
    },
    {
      "RevelationOrder": 205,
      "TurkishTranslation": "Oysa ahiret daha iyi ve daha bakidir.",
      "ArabicText": "وَٱلْءَاخِرَةُ خَيْرٌۭ وَأَبْقَىٰٓ",
      "Number": 17
    },
    {
      "RevelationOrder": 206,
      "TurkishTranslation": "Doğrusu bu hükümler ilk sahifelerde, İbrahim ve Musa'nın sahifelerinde de vardır.",
      "ArabicText": "إِنَّ هَٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ",
      "Number": 18
    },
    {
      "RevelationOrder": 207,
      "TurkishTranslation": "Doğrusu bu hükümler ilk sahifelerde, İbrahim ve Musa'nın sahifelerinde de vardır.",
      "ArabicText": "صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ",
      "Number": 19
    }
  ],
  "SurahName": "سُورَةُ الأَعۡلَىٰ"
}
