{
  "SurahEnglishName": "Ad-Dhuhaa",
  "SurahNumber": 93,
  "RevelationOrder": 11,
  "Verses": [
    {
      "RevelationOrder": 259,
      "TurkishTranslation": "Kuşluk vaktine and olsun;",
      "ArabicText": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ",
      "Number": 1
    },
    {
      "RevelationOrder": 260,
      "TurkishTranslation": "Sükun erdiği zaman geceye and olsun ki,",
      "ArabicText": "وَٱلَّيْلِ إِذَا سَجَىٰ",
      "Number": 2
    },
    {
      "RevelationOrder": 261,
      "TurkishTranslation": "Rabbin seni ne bıraktı ve ne de sana darıldı.",
      "ArabicText": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
      "Number": 3
    },
    {
      "RevelationOrder": 262,
      "TurkishTranslation": "Doğrusu ahiret senin için dünyadan daha hayırlıdır.",
      "ArabicText": "وَلَلْءَاخِرَةُ خَيْرٌۭ لَّكَ مِنَ ٱلْأُولَىٰ",
      "Number": 4
    },
    {
      "RevelationOrder": 263,
      "TurkishTranslation": "Rabbin şüphesiz sana verecek ve sen de hoşnut olacaksın.",
      "ArabicText": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ",
      "Number": 5
    },
    {
      "RevelationOrder": 264,
      "TurkishTranslation": "Seni öksüz bulup da barındırmadı mı?",
      "ArabicText": "أَلَمْ يَجِدْكَ يَتِيمًۭا فَـَٔاوَىٰ",
      "Number": 6
    },
    {
      "RevelationOrder": 265,
      "TurkishTranslation": "Seni şaşırmış bulup, doğru yola eriştirmedi mi?",
      "ArabicText": "وَوَجَدَكَ ضَآلًّۭا فَهَدَىٰ",
      "Number": 7
    },
    {
      "RevelationOrder": 266,
      "TurkishTranslation": "Seni fakir bulup zenginleştirmedi mi?",
      "ArabicText": "وَوَجَدَكَ عَآئِلًۭا فَأَغْنَىٰ",
      "Number": 8
    },
    {
      "RevelationOrder": 267,
      "TurkishTranslation": "Öyleyse sakın öksüze kötü muamele etme;",
      "ArabicText": "فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ",
      "Number": 9
    },
    {
      "RevelationOrder": 268,
      "TurkishTranslation": "Ve sakın bir şey isteyeni azarlama;",
      "ArabicText": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ",
      "Number": 10
    },
    {
      "RevelationOrder": 269,
      "TurkishTranslation": "Yalnızca Rabbinin nimetini anlat.",
      "ArabicText": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
      "Number": 11
    }
  ],
  "SurahName": "سُورَةُ الضُّحَىٰ"
}
