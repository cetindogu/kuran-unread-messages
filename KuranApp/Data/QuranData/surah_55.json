{
  "SurahEnglishName": "Ar-Rahmaan",
  "SurahNumber": 55,
  "RevelationOrder": 97,
  "Verses": [
    {
      "RevelationOrder": 5555,
      "TurkishTranslation": "Rahman olan Allah Kuran'ı öğretti;",
      "ArabicText": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلرَّحْمَٰنُ",
      "Number": 1
    },
    {
      "RevelationOrder": 5556,
      "TurkishTranslation": "Rahman olan Allah Kuran'ı öğretti;",
      "ArabicText": "عَلَّمَ ٱلْقُرْءَانَ",
      "Number": 2
    },
    {
      "RevelationOrder": 5557,
      "TurkishTranslation": "İnsanı yarattı, ona konuşmayı öğretti.",
      "ArabicText": "خَلَقَ ٱلْإِنسَٰنَ",
      "Number": 3
    },
    {
      "RevelationOrder": 5558,
      "TurkishTranslation": "İnsanı yarattı, ona konuşmayı öğretti.",
      "ArabicText": "عَلَّمَهُ ٱلْبَيَانَ",
      "Number": 4
    },
    {
      "RevelationOrder": 5559,
      "TurkishTranslation": "Güneş ve ayın hareketleri bir hesaba göredir.",
      "ArabicText": "ٱلشَّمْسُ وَٱلْقَمَرُ بِحُسْبَانٍۢ",
      "Number": 5
    },
    {
      "RevelationOrder": 5560,
      "TurkishTranslation": "Bitkiler ve ağaçlar O'nun buyruğuna boyun eğerler.",
      "ArabicText": "وَٱلنَّجْمُ وَٱلشَّجَرُ يَسْجُدَانِ",
      "Number": 6
    },
    {
      "RevelationOrder": 5561,
      "TurkishTranslation": "O, göğü yükseltmiştir; tartıyı koymuştur.",
      "ArabicText": "وَٱلسَّمَآءَ رَفَعَهَا وَوَضَعَ ٱلْمِيزَانَ",
      "Number": 7
    },
    {
      "RevelationOrder": 5562,
      "TurkishTranslation": "Artık tartıda tecavüz etmeyin.",
      "ArabicText": "أَلَّا تَطْغَوْا۟ فِى ٱلْمِيزَانِ",
      "Number": 8
    },
    {
      "RevelationOrder": 5563,
      "TurkishTranslation": "Tartmayı doğru yapın, tartıyı eksik tutmayın.",
      "ArabicText": "وَأَقِيمُوا۟ ٱلْوَزْنَ بِٱلْقِسْطِ وَلَا تُخْسِرُوا۟ ٱلْمِيزَانَ",
      "Number": 9
    },
    {
      "RevelationOrder": 5564,
      "TurkishTranslation": "Allah, yeri yaratıkları için meydana getirmiştir.",
      "ArabicText": "وَٱلْأَرْضَ وَضَعَهَا لِلْأَنَامِ",
      "Number": 10
    },
    {
      "RevelationOrder": 5565,
      "TurkishTranslation": "Orada meyveler, salkımlı hurma ağaçları, kabuklu taneler, güzel kokulu otlar vardır.",
      "ArabicText": "فِيهَا فَٰكِهَةٌۭ وَٱلنَّخْلُ ذَاتُ ٱلْأَكْمَامِ",
      "Number": 11
    },
    {
      "RevelationOrder": 5566,
      "TurkishTranslation": "Orada meyveler, salkımlı hurma ağaçları, kabuklu taneler, güzel kokulu otlar vardır.",
      "ArabicText": "وَٱلْحَبُّ ذُو ٱلْعَصْفِ وَٱلرَّيْحَانُ",
      "Number": 12
    },
    {
      "RevelationOrder": 5567,
      "TurkishTranslation": "Ey insanlar ve cinler! Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?",
      "ArabicText": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ",
      "Number": 13
    },
    {
      "RevelationOrder": 5568,
      "TurkishTranslation": "O, insanı pişmiş çamur gibi kuru balçıktan yaratmıştır.",
      "ArabicText": "خَلَقَ ٱلْإِنسَٰنَ مِن صَلْصَٰلٍۢ كَٱلْفَخَّارِ",
      "Number": 14
    },
    {
      "RevelationOrder": 5569,
      "TurkishTranslation": "Cinleri de yalın bir alevden yaratmıştır.",
      "ArabicText": "وَخَلَقَ ٱلْجَآنَّ مِن مَّارِجٍۢ مِّن نَّارٍۢ",
      "Number": 15
    },
    {
      "RevelationOrder": 5570,
      "TurkishTranslation": "Öyleyken; Rabbinizin nimetlerinden hangisini yalanlarsınız?",
      "ArabicText": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ",
      "Number": 16
    },
    {
      "RevelationOrder": 5571,
      "TurkishTranslation": "O, iki doğunun Rabbidir, iki batının Rabbidir.",
      "ArabicText": "رَبُّ ٱلْمَشْرِقَيْنِ وَرَبُّ ٱلْمَغْرِبَيْنِ",
      "Number": 17
    },
    {
      "RevelationOrder": 5572,
      "TurkishTranslation": "Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?",
      "ArabicText": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ",
      "Number": 18
    },
    {
      "RevelationOrder": 5573,
      "TurkishTranslation": "Acı ve tatlı sulu iki denizi birbirine kavuşmamak üzere salıvermiştir.",
      "ArabicText": "مَرَجَ ٱلْبَحْرَيْنِ يَلْتَقِيَانِ",
      "Number": 19
    },
    {
      "RevelationOrder": 5574,
      "TurkishTranslation": "Aralarında bir engel vardır; birbirinin sınırını aşamazlar.",
      "ArabicText": "بَيْنَهُمَا بَرْزَخٌۭ لَّا يَبْغِيَانِ",
      "Number": 20
    },
    {
      "RevelationOrder": 5575,
      "TurkishTranslation": "Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?",
      "ArabicText": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ",
      "Number": 21
    },
    {
      "RevelationOrder": 5576,
      "TurkishTranslation": "Bu iki denizden de inci ve mercan çıkar.",
      "ArabicText": "يَخْرُجُ مِنْهُمَا ٱللُّؤْلُؤُ وَٱلْمَرْجَانُ",
      "Number": 22
    },
    {
      "RevelationOrder": 5577,
      "TurkishTranslation": "Öyleyken Rabbinizin nimetlerinden hangisini yalanlarsınız?",
      "ArabicText": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ",
      "Number": 23
    },
    {
      "RevelationOrder": 5578,
      "TurkishTranslation": "Denizde yürüyen dağlar gibi gemiler O'nundur.",
      "ArabicText": "وَلَهُ ٱلْجَوَارِ ٱلْمُنشَـَٔاتُ فِى ٱلْبَحْرِ كَٱلْأَعْلَٰمِ",
      "Number": 24
    },
    {
      "RevelationOrder": 5579,
      "TurkishTranslation": "Öyleyken Rabbinizin nimetlerinden hangisini yalanlarsınız?",
      "ArabicText": "فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ",
      "Number": 25
    },
    {
      "RevelationOrder": 5580,
      "TurkishTranslation": "Yeryüzünde bulunan her şey fanidir.",
