      "Number": 49
    },
    {
      "RevelationOrder": 5604,
      "TurkishTranslation": "Bu cennetlerden akan iki kaynak vardır.",
      "ArabicText": "فِيهِمَا عَيْنَانِ تَجْرِيَانِ",
