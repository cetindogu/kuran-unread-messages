{
  "SurahEnglishName": "Ash-Shams",
  "SurahNumber": 91,
  "RevelationOrder": 26,
  "Verses": [
    {
      "RevelationOrder": 445,
      "TurkishTranslation": "Güneşe ve onun ışığına,",
      "ArabicText": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلشَّمْسِ وَضُحَىٰهَا",
      "Number": 1
    },
    {
      "RevelationOrder": 446,
      "TurkishTranslation": "Ardından gelmekte olan aya,",
      "ArabicText": "وَٱلْقَمَرِ إِذَا تَلَىٰهَا",
      "Number": 2
    },
    {
      "RevelationOrder": 447,
      "TurkishTranslation": "Onu ortaya koyan gündüze,",
      "ArabicText": "وَٱلنَّهَارِ إِذَا جَلَّىٰهَا",
      "Number": 3
    },
    {
      "RevelationOrder": 448,
      "TurkishTranslation": "Onu bürüyen geceye,",
      "ArabicText": "وَٱلَّيْلِ إِذَا يَغْشَىٰهَا",
      "Number": 4
    },
    {
      "RevelationOrder": 449,
      "TurkishTranslation": "Göğe ve onu yapana,",
      "ArabicText": "وَٱلسَّمَآءِ وَمَا بَنَىٰهَا",
      "Number": 5
    },
    {
      "RevelationOrder": 450,
      "TurkishTranslation": "Yere ve onu yayana,",
      "ArabicText": "وَٱلْأَرْضِ وَمَا طَحَىٰهَا",
      "Number": 6
    },
    {
      "RevelationOrder": 451,
      "TurkishTranslation": "Kişiye ve onu şekillendirene,",
      "ArabicText": "وَنَفْسٍۢ وَمَا سَوَّىٰهَا",
      "Number": 7
    },
    {
      "RevelationOrder": 452,
      "TurkishTranslation": "Sonra da ona iyilik ve kötülük kabiliyeti verene and olsun ki:",
      "ArabicText": "فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَىٰهَا",
      "Number": 8
    },
    {
      "RevelationOrder": 453,
      "TurkishTranslation": "Kendini arıtan saadete ermiştir.",
      "ArabicText": "قَدْ أَفْلَحَ مَن زَكَّىٰهَا",
      "Number": 9
    },
    {
      "RevelationOrder": 454,
      "TurkishTranslation": "Kendini fenalıklara gömen kimse de ziyana uğramıştır.",
      "ArabicText": "وَقَدْ خَابَ مَن دَسَّىٰهَا",
      "Number": 10
    },
    {
      "RevelationOrder": 455,
      "TurkishTranslation": "Semud milleti, içlerinden en azgını ileri atılınca, azgınlığı yüzünden peygamberleri yalanladı.",
      "ArabicText": "كَذَّبَتْ ثَمُودُ بِطَغْوَىٰهَآ",
      "Number": 11
    },
    {
      "RevelationOrder": 456,
      "TurkishTranslation": "Semud milleti, içlerinden en azgını ileri atılınca, azgınlığı yüzünden peygamberleri yalanladı.",
      "ArabicText": "إِذِ ٱنۢبَعَثَ أَشْقَىٰهَا",
      "Number": 12
    },
    {
      "RevelationOrder": 457,
      "TurkishTranslation": "Allah'ın peygamberi onlara, Allah'ın devesini göstermiş ve: \"Allah'ın bu devesine ve onun su hakkına dokunmayın\" demişti.",
      "ArabicText": "فَقَالَ لَهُمْ رَسُولُ ٱللَّهِ نَاقَةَ ٱللَّهِ وَسُقْيَٰهَا",
      "Number": 13
    },
    {
      "RevelationOrder": 458,
      "TurkishTranslation": "Onu yalanladılar ve deveyi boğazladılar. Bunun üzerine Rableri, suçlarından dolayı onların üzerine katmerli azap indirdi; yerle bir etti onları.",
      "ArabicText": "فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُم بِذَنۢبِهِمْ فَسَوَّىٰهَا",
      "Number": 14
    },
    {
      "RevelationOrder": 459,
      "TurkishTranslation": "Bu işin sonundan O'nun korkusu yoktur.",
      "ArabicText": "وَلَا يَخَافُ عُقْبَٰهَا",
      "Number": 15
    }
  ],
  "SurahName": "سُورَةُ الشَّمۡسِ"
}
