{
  "SurahEnglishName": "At-Takaathur",
  "SurahNumber": 102,
  "RevelationOrder": 16,
  "Verses": [
    {
      "RevelationOrder": 295,
      "TurkishTranslation": "Çoğunluk olmak iddianız sizi o kadar meşgul etti ki, mezarları ziyaretle oradakileri de sayacak kadar oldunuz.",
      "ArabicText": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلْهَىٰكُمُ ٱلتَّكَاثُرُ",
      "Number": 1
    },
    {
      "RevelationOrder": 296,
      "TurkishTranslation": "Çoğunluk olmak iddianız sizi o kadar meşgul etti ki, mezarları ziyaretle oradakileri de sayacak kadar oldunuz.",
      "ArabicText": "حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ",
      "Number": 2
    },
    {
      "RevelationOrder": 297,
      "TurkishTranslation": "Hayır; öyle olmayın; yakında bileceksiniz.",
      "ArabicText": "كَلَّا سَوْفَ تَعْلَمُونَ",
      "Number": 3
    },
    {
      "RevelationOrder": 298,
      "TurkishTranslation": "Hayır; gözünüzü açın; yakında bileceksiniz.",
      "ArabicText": "ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ",
      "Number": 4
    },
    {
      "RevelationOrder": 299,
      "TurkishTranslation": "Dikkat edin, şayet yaptığınızın sonucunu kesin olarak bir bilseniz!",
      "ArabicText": "كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ",
      "Number": 5
    },
    {
      "RevelationOrder": 300,
      "TurkishTranslation": "And olsun ki, cehennemi göreceksiniz.",
      "ArabicText": "لَتَرَوُنَّ ٱلْجَحِيمَ",
      "Number": 6
    },
    {
      "RevelationOrder": 301,
      "TurkishTranslation": "And olsun ki, onu gözünüzle kesin olarak göreceksiniz.",
      "ArabicText": "ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ",
      "Number": 7
    },
    {
      "RevelationOrder": 302,
      "TurkishTranslation": "Sonra o gün, size verilmiş olan her nimetten sorguya çekileceksiniz.",
      "ArabicText": "ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ",
      "Number": 8
    }
  ],
  "SurahName": "سُورَةُ التَّكَاثُرِ"
}
