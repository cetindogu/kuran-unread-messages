{
  "SurahEnglishName": "At-Taariq",
  "SurahNumber": 86,
  "RevelationOrder": 36,
  "Verses": [
    {
      "RevelationOrder": 669,
      "TurkishTranslation": "Göğe ve Tarık'a and olsun;",
      "ArabicText": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ",
      "Number": 1
    },
    {
      "RevelationOrder": 670,
      "TurkishTranslation": "Tarık'ın ne olduğunu sen bilir misin?",
      "ArabicText": "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ",
      "Number": 2
    },
    {
      "RevelationOrder": 671,
      "TurkishTranslation": "O, (ışığıyla karanlığı) delen yıldızdır.",
      "ArabicText": "ٱلنَّجْمُ ٱلثَّاقِبُ",
      "Number": 3
    },
    {
      "RevelationOrder": 672,
      "TurkishTranslation": "Üzerinde gözetici olmayan kimse yoktur.",
      "ArabicText": "إِن كُلُّ نَفْسٍۢ لَّمَّا عَلَيْهَا حَافِظٌۭ",
      "Number": 4
    },
    {
      "RevelationOrder": 673,
      "TurkishTranslation": "Öyleyse insan neden yaratıldığına bir baksın.",
      "ArabicText": "فَلْيَنظُرِ ٱلْإِنسَٰنُ مِمَّ خُلِقَ",
      "Number": 5
    },
    {
      "RevelationOrder": 674,
      "TurkishTranslation": "O, erkek ve kadının beli ile kaburga kemikleri arasından atılagelen bir sudan yaratılmıştır.",
      "ArabicText": "خُلِقَ مِن مَّآءٍۢ دَافِقٍۢ",
      "Number": 6
    },
    {
      "RevelationOrder": 675,
      "TurkishTranslation": "O, erkek ve kadının beli ile kaburga kemikleri arasından atılagelen bir sudan yaratılmıştır.",
      "ArabicText": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ",
      "Number": 7
    },
    {
      "RevelationOrder": 676,
      "TurkishTranslation": "Şüphesiz Allah, gizliliklerin ortaya çıkacağı gün, insanı tekrar yaratmaya Kadir'dir.",
      "ArabicText": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌۭ",
      "Number": 8
    },
    {
      "RevelationOrder": 677,
      "TurkishTranslation": "Şüphesiz Allah, gizliliklerin ortaya çıkacağı gün, insanı tekrar yaratmaya Kadir'dir.",
      "ArabicText": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ",
      "Number": 9
    },
    {
      "RevelationOrder": 678,
      "TurkishTranslation": "O gün, insanın gücü de, yardımcısı da olmaz.",
      "ArabicText": "فَمَا لَهُۥ مِن قُوَّةٍۢ وَلَا نَاصِرٍۢ",
      "Number": 10
    },
    {
      "RevelationOrder": 679,
      "TurkishTranslation": "Dönüşlü göğe ve yarılan yeryüzüne and olsun ki,",
      "ArabicText": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ",
      "Number": 11
    },
    {
      "RevelationOrder": 680,
      "TurkishTranslation": "Dönüşlü göğe ve yarılan yeryüzüne and olsun ki,",
      "ArabicText": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ",
      "Number": 12
    },
    {
      "RevelationOrder": 681,
      "TurkishTranslation": "Doğrusu bu Kuran kesin bir sözdür.",
      "ArabicText": "إِنَّهُۥ لَقَوْلٌۭ فَصْلٌۭ",
      "Number": 13
    },
    {
      "RevelationOrder": 682,
      "TurkishTranslation": "O, eğlence için değildir.",
      "ArabicText": "وَمَا هُوَ بِٱلْهَزْلِ",
      "Number": 14
    },
    {
      "RevelationOrder": 683,
      "TurkishTranslation": "Gerçekten onlar düzen kuruyorlar.",
      "ArabicText": "إِنَّهُمْ يَكِيدُونَ كَيْدًۭا",
      "Number": 15
    },
    {
      "RevelationOrder": 684,
      "TurkishTranslation": "Ben de bir düzen kurmaktayım.",
      "ArabicText": "وَأَكِيدُ كَيْدًۭا",
      "Number": 16
    },
    {
      "RevelationOrder": 685,
      "TurkishTranslation": "Sen inkarcılara mehil ver; onlara mukabeleyi biraz geri bırak.",
      "ArabicText": "فَمَهِّلِ ٱلْكَٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا",
      "Number": 17
    }
  ],
  "SurahName": "سُورَةُ الطَّارِقِ"
}
