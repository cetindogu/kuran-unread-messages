{
  "SurahEnglishName": "Ash-Sharh",
  "SurahNumber": 94,
  "RevelationOrder": 12,
  "Verses": [
    {
      "RevelationOrder": 270,
      "TurkishTranslation": "Senin gönlünü açmadık mı?",
      "ArabicText": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ",
      "Number": 1
    },
    {
      "RevelationOrder": 271,
      "TurkishTranslation": "Belini büken yükünü üzerinden almadık mı?",
      "ArabicText": "وَوَضَعْنَا عَنكَ وِزْرَكَ",
      "Number": 2
    },
    {
      "RevelationOrder": 272,
      "TurkishTranslation": "Belini büken yükünü üzerinden almadık mı?",
      "ArabicText": "ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ",
      "Number": 3
    },
    {
      "RevelationOrder": 273,
      "TurkishTranslation": "Senin şanını yükseltmedik mi?",
      "ArabicText": "وَرَفَعْنَا لَكَ ذِكْرَكَ",
      "Number": 4
    },
    {
      "RevelationOrder": 274,
      "TurkishTranslation": "Elbette güçlükle beraber şüphesiz bir kolaylık vardır.",
      "ArabicText": "فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا",
      "Number": 5
    },
    {
      "RevelationOrder": 275,
      "TurkishTranslation": "Gerçekten, güçlükle beraber bir kolaylık vardır.",
      "ArabicText": "إِنَّ مَعَ ٱلْعُسْرِ يُسْرًۭا",
      "Number": 6
    },
    {
      "RevelationOrder": 276,
      "TurkishTranslation": "Öyleyse, bir işi bitirince diğerine giriş;",
      "ArabicText": "فَإِذَا فَرَغْتَ فَٱنصَبْ",
      "Number": 7
    },
    {
      "RevelationOrder": 277,
      "TurkishTranslation": "Ve ümit edeceğini yalnız Rabbinden iste.",
      "ArabicText": "وَإِلَىٰ رَبِّكَ فَٱرْغَب",
      "Number": 8
    }
  ],
  "SurahName": "سُورَةُ الشَّرۡحِ"
}
