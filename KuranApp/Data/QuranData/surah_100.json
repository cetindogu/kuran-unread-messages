{
  "SurahEnglishName": "Al-Aadiyaat",
  "SurahNumber": 100,
  "RevelationOrder": 14,
  "Verses": [
    {
      "RevelationOrder": 281,
      "TurkishTranslation": "And olsun Allah yolunda koştukça koşanlara;",
      "ArabicText": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْعَٰدِيَٰتِ ضَبْحًۭا",
      "Number": 1
    },
    {
      "RevelationOrder": 282,
      "TurkishTranslation": "And olsun kıvılcımlar saçanlara;",
      "ArabicText": "فَٱلْمُورِيَٰتِ قَدْحًۭا",
      "Number": 2
    },
    {
      "RevelationOrder": 283,
      "TurkishTranslation": "Sabah sabah akına çıkanlara;",
      "ArabicText": "فَٱلْمُغِيرَٰتِ صُبْحًۭا",
      "Number": 3
    },
    {
      "RevelationOrder": 284,
      "TurkishTranslation": "Ve tozu dumana katanlara;",
      "ArabicText": "فَأَثَرْنَ بِهِۦ نَقْعًۭا",
      "Number": 4
    },
    {
      "RevelationOrder": 285,
      "TurkishTranslation": "Düşman topluluğunun içine dalanlara ki:",
      "ArabicText": "فَوَسَطْنَ بِهِۦ جَمْعًا",
      "Number": 5
    },
    {
      "RevelationOrder": 286,
      "TurkishTranslation": "İnsan gerçekten Rabbine karşı pek nankördür.",
      "ArabicText": "إِنَّ ٱلْإِنسَٰنَ لِرَبِّهِۦ لَكَنُودٌۭ",
      "Number": 6
    },
    {
      "RevelationOrder": 287,
      "TurkishTranslation": "Doğrusu kendisi de bunların hepsine şahittir.",
      "ArabicText": "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌۭ",
      "Number": 7
    },
    {
      "RevelationOrder": 288,
      "TurkishTranslation": "Gerçekten mala da pek düşkündür.",
      "ArabicText": "وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ",
      "Number": 8
    },
    {
      "RevelationOrder": 289,
      "TurkishTranslation": "İnsan, kabirlerde bulunanların çıkarılacağı ve kalblerde olanların ortaya konulacağı bir zamanın geleceğini bilmez mi?",
      "ArabicText": "۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ",
      "Number": 9
    },
    {
      "RevelationOrder": 290,
      "TurkishTranslation": "İnsan, kabirlerde bulunanların çıkarılacağı ve kalblerde olanların ortaya konulacağı bir zamanın geleceğini bilmez mi?",
      "ArabicText": "وَحُصِّلَ مَا فِى ٱلصُّدُورِ",
      "Number": 10
    },
    {
      "RevelationOrder": 291,
      "TurkishTranslation": "Doğrusu Rableri o gün onların her şeyinden haberdardır.",
      "ArabicText": "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍۢ لَّخَبِيرٌۢ",
      "Number": 11
    }
  ],
  "SurahName": "سُورَةُ العَادِيَاتِ"
}
