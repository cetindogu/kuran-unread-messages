{
  "SurahEnglishName": "Al-Maa'un",
  "SurahNumber": 107,
  "RevelationOrder": 17,
  "Verses": [
    {
      "RevelationOrder": 303,
      "TurkishTranslation": "Dini yalan sayanı gördün mü?",
      "ArabicText": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ",
      "Number": 1
    },
    {
      "RevelationOrder": 304,
      "TurkishTranslation": "Öksüzü kakıştıran, yoksulu doyurmaya yanaşmayan kimse işte odur.",
      "ArabicText": "فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ",
      "Number": 2
    },
    {
      "RevelationOrder": 305,
      "TurkishTranslation": "Öksüzü kakıştıran, yoksulu doyurmaya yanaşmayan kimse işte odur.",
      "ArabicText": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
      "Number": 3
    },
    {
      "RevelationOrder": 306,
      "TurkishTranslation": "Vay o namaz kılanların haline ki:",
      "ArabicText": "فَوَيْلٌۭ لِّلْمُصَلِّينَ",
      "Number": 4
    },
    {
      "RevelationOrder": 307,
      "TurkishTranslation": "Onlar kıldıkları namazdan gafildirler.",
      "ArabicText": "ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
      "Number": 5
    },
    {
      "RevelationOrder": 308,
      "TurkishTranslation": "Onlar gösteriş yaparlar.",
      "ArabicText": "ٱلَّذِينَ هُمْ يُرَآءُونَ",
      "Number": 6
    },
    {
      "RevelationOrder": 309,
      "TurkishTranslation": "Onlar basit şeyleri dahi vermezler.",
      "ArabicText": "وَيَمْنَعُونَ ٱلْمَاعُونَ",
      "Number": 7
    }
  ],
  "SurahName": "سُورَةُ المَاعُونِ"
}
